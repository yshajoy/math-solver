{
  "name": "math-solver",
  "version": "1.1.0",
  "description": "Complete mathematical problem solving with OCR, LaTeX extraction, PNG rendering, and guided solutions",
  
  "dependencies": {
    "skills": [
      {
        "name": "paddleocr-doc-parsing",
        "version": ">=1.0.0",
        "required": true,
        "purpose": "Extract text and formulas from images"
      }
    ],
    "python": {
      "version": ">=3.8",
      "packages": [
        "matplotlib>=3.5.0",
        "Pillow>=9.0.0",
        "numpy>=1.20.0",
        "opencv-python>=4.5.0"
      ]
    }
  },
  
  "security": {
    "requires_review": false,
    "external_apis": [],
    "file_system_access": "read-only",
    "network_access": false,
    "prompt_injection_protection": true,
    "data_storage": "none",
    "credentials_required": false
  },
  
  "capabilities": [
    "image-processing",
    "ocr",
    "latex-conversion",
    "formula-rendering",
    "problem-solving",
    "educational-guidance"
  ]
}
